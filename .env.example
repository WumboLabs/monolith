# Monolith alpha local setup example
#
# Copy this file to .env if you want to document your local paths.
# Monolith does not automatically load .env yet; export these variables
# in your shell before starting uvicorn, or put them in your service wrapper.

# Optional: override the SQLite database path.
# Default: ./data/llm-tests.sqlite
# MONOLITH_DB_PATH=/absolute/path/to/llm-tests.sqlite

# Optional: override the model configuration file.
# Default: ./configs/models.yaml
# MONOLITH_MODELS_CONFIG=/absolute/path/to/models.yaml

# Optional: colon-separated list of local model roots scanned by /models.
# Generic public-alpha default:
#   ~/Monolith/models
MONOLITH_MODEL_INVENTORY_ROOTS=$HOME/Monolith/models

# Optional: approved root for Hugging Face GGUF downloads.
# Downloaded models are placed under:
#   <root>/<owner>--<repo>/<filename>.gguf
MONOLITH_MODEL_DOWNLOAD_ROOT=$HOME/Monolith/models/huggingface

# Optional: Quant Lab integration root.
# Default: ./quant-lab
# MONOLITH_QUANT_LAB_ROOT=$HOME/Monolith/quant-lab

# Monolith WebUI
# Canonical local development URL: http://127.0.0.1:8765/
MONOLITH_WEB_HOST=127.0.0.1
MONOLITH_WEB_PORT=8765
